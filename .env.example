# Connection for the live integration tests and the playground.
# Either provide the full URL...
FIDELIO_URL=https://host/V8CF/fidelioIISWrapper.dll/FidelioXMLInterface.DataHandler?ic=XX
# ...or its parts (used when FIDELIO_URL is not set):
FIDELIO_ENDPOINT=https://host
FIDELIO_PATH=/fidelioIISWrapper.dll/FidelioXMLInterface.DataHandler?ic=
FIDELIO_CODE=XX

FIDELIO_VERSION=1.1.0
FIDELIO_USERNAME=API
FIDELIO_VENDOR=API
FIDELIO_PASSWORD=
USER_AGENT=FidelioNodeService

# Log raw request/response XML to the console
DEBUG_ENABLED=false

# Live records the integration tests are allowed to read AND MODIFY
TEST_RESERVATION_ID=42447
TEST_RESERVATION_NOTE_ATTR=NF
TEST_PROFILE_PRIMARY=477822
TEST_PROFILE_SECONDARY=556001
