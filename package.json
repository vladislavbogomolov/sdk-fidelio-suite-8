{
  "name": "sdk-fidelio-suite",
  "version": "2.1.0",
  "description": "TypeScript SDK for the Fidelio Suite 8 hotel PMS XML interface (V8/ZIP protocol)",
  "main": "dist/index.js",
  "type": "commonjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vladislavbogomolov/sdk-fidelio-suite-8.git"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit -p tsconfig.test.json",
    "test": "TZ=UTC jest --runInBand",
    "test:watch": "TZ=UTC jest --watchAll --runInBand --logHeapUsage",
    "test:golden": "TZ=UTC jest test/golden",
    "test:offline": "TZ=UTC jest test/golden test/unit",
    "golden:update": "TZ=UTC ts-node -P tsconfig.test.json test/golden/helpers/update-golden.ts",
    "start": "nodemon playground.ts",
    "prepublishOnly": "npm run build",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "fidelio",
    "suite8",
    "pms",
    "hotel",
    "oracle-hospitality",
    "sdk"
  ],
  "author": "Vladislav Bogomolov",
  "license": "Apache-2.0",
  "dependencies": {
    "axios": "^1.11.0",
    "dayjs": "^1.11.13",
    "jszip": "^3.10.1",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@eslint/js": "^10.0.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.20.1",
    "@types/xml2js": "^0.4.14",
    "dotenv": "^16.6.1",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "nodemon": "^3.1.14",
    "semantic-release": "^25.0.7",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.64.0"
  }
}
